# Patent Agency API Credentials
# Get your API ID and password from https://ip-data.jpo.go.jp/pages/top.html
JPO_API_ID=YOUR_API_ID
JPO_API_PASSWORD=YOUR_API_PASSWORD

# Slack Webhook URL
# Get your webhook URL from your Slack workspace settings
SLACK_WEBHOOK_URL=YOUR_WEBHOOK_URL

# API Configuration
JPO_TOKEN_URL=https://ip-data.jpo.go.jp/auth/token
